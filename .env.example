# Copy this file to .env and fill in real values. .env is gitignored.
# Required for the backend to boot — config.py will exit if any are missing.

# LLM + search providers
GROQ_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=

# Supabase — get these from your Supabase project's API settings page.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Supabase Postgres connection string.
# Local dev: direct URL is fine.
# Prod (Render): use the Transaction Pooler URL (port 6543), not the direct one.
# Either DATABASE_URL or SUPABASE_DB_URL works — config.py checks both.
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# CORS — comma-separated list of allowed frontend origins.
# Dev:  http://localhost:3000
# Prod: https://your-vercel-domain.com,http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Where the frontend lives — used to build "browse mentors" links in LLM responses.
FRONTEND_URL=http://localhost:3000

# Cal.com webhook signature secret. Set the same value in the Cal dashboard when
# registering the webhook (Settings → Developer → Webhooks). Optional — without it
# the /webhooks/cal endpoint returns 503 and everything else works normally.
CAL_WEBHOOK_SECRET=

# Optional: render the LangGraph PNG on startup (dev convenience only).
# DRAW_GRAPH=true
